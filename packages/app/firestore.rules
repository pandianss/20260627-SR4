rules_version = '2';

// Security rules for SuperRecall Banker (project: superrecall-3afe5).
// Each signed-in user (including anonymous) can read/write only their own data
// under users/{uid}/**. Nothing else is accessible.
//
// Deploy: paste into Firebase console → Firestore Database → Rules,
// or `firebase deploy --only firestore:rules` once firebase.json references it.
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;
    }
  }
}
